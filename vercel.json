{
    "rewrites": {
        "beforeFiles": [
            {
                "source": "/(.*)",
                "has": [
                    {
                        "type": "header",
                        "key": "user-agent",
                        "value": "(?i).*(whatsapp|telegrambot|facebookexternalhit|twitterbot|linkedinbot|discordbot|slackbot|vkShare).*"
                    }
                ],
                "destination": "/api/bot.js"
            }
        ],
        "afterFiles": [
            {
                "source": "/(.*)",
                "destination": "/index.html"
            }
        ]
    }
}